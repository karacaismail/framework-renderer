{
  "name": "framework-renderer",
  "version": "0.1.0",
  "description": "JSON-driven block renderer for the framework master doc",
  "type": "module",
  "license": "LGPL-3.0-only",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "postbuild": "tsx scripts/generate-sitemap.ts",
    "preview": "vite preview --host",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test tests/a11y.spec.ts",
    "test:visual": "playwright test tests/visual.spec.ts",
    "test:visual:update": "playwright test tests/visual.spec.ts --update-snapshots",
    "validate:content": "tsx scripts/validate-content.ts",
    "sync:last-updated": "tsx scripts/sync-last-updated.ts --write",
    "audit:60plus": "tsx scripts/audit-60plus.ts",
    "audit:mobile": "tsx scripts/audit-mobile-first.ts",
    "audit:mobile:strict": "tsx scripts/audit-mobile-first.ts --strict"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.9.0",
    "@playwright/test": "^1.45.0",
    "@types/marked": "^5.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "jsdom": "^24.0.0",
    "sass": "^1.77.0",
    "tsx": "^4.16.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "marked": "^12.0.0",
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "web-vitals": "^4.2.0"
  }
}
